{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agentguide",
  "main": "src/index.js",
  "compatibility_date": "2026-05-23",

  // ── 정적 자산 (public/) ─────────────────────────
  // 가이드 페이지(index.html)를 서비스한다. /api/* 가 아닌 경로는
  // Worker가 env.ASSETS.fetch()로 이 자산을 돌려준다.
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },

  // ── 라우트 (전용 서브도메인) ────────────────────
  // 전용 서브도메인 agentguide.samsungda.net 으로 서비스한다. zone(samsungda.net)이
  // 같은 Cloudflare 계정의 영역이어야 한다. 서브도메인을 바꾸려면 아래 pattern만
  // 수정하면 된다. DNS/Custom Domain 연결은 대시보드가 아니라 이 custom_domain
  // 라우트로 관리한다.
  "routes": [
    { "pattern": "agentguide.samsungda.net", "custom_domain": true }
  ],

  // 자료 출처(GitHub Releases). 비공개 저장소이므로 GITHUB_TOKEN(secret)이 필요하다:
  //   wrangler secret put GITHUB_TOKEN
  "vars": {
    "GITHUB_OWNER": "SimpleorNothing",
    "GITHUB_REPO": "report-site"
  },

  // ── 조사 결과물(메뉴3) R2 버킷 ──────────────────
  // 포털(samsungda-portal)과 "같은" 버킷을 공유한다. 한쪽에서 올린 파일이 양쪽에
  // 동일하게 보이며, 업로드/삭제 메타데이터(비밀번호 해시 등)도 호환된다. 포털은
  // 사이트 비밀번호 게이트가 있어 서버 프록시로는 접근할 수 없으므로 직접 바인딩한다.
  "r2_buckets": [
    { "binding": "RESEARCH", "bucket_name": "samsungda-research" }
  ],

  "observability": {
    "enabled": true
  }
}
